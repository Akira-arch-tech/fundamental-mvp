{
  "name": "fundamental-mvp-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "check": "npm run build && npm run verify:clickflow && npm run verify:mvp",
    "predev": "node scripts/assert-next-app-root.mjs",
    "dev": "NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:clean": "node scripts/assert-next-app-root.mjs && rm -rf .next && NEXT_DISABLE_TURBOPACK=1 next dev",
    "verify:clickflow": "node verify-clickflow.mjs",
    "verify:mvp": "node verify-mvp.mjs",
    "smoke:aigc:fal": "node scripts/aigc-smoke-fal.mjs",
    "smoke:aigc:dashscope": "node scripts/aigc-smoke-dashscope.mjs",
    "smoke:aigc:ttapi": "node scripts/aigc-smoke-ttapi.mjs",
    "smoke:pillar2": "node scripts/pillar2-pov-placeholder.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed-users.ts",
    "verify:with-db": "npm run db:seed && VERIFY_CLICKFLOW_WITH_DB=1 node verify-clickflow.mjs && VERIFY_CLICKFLOW_WITH_DB=1 node verify-mvp.mjs"
  },
  "dependencies": {
    "@vercel/blob": "^1.1.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.6",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.75.0",
    "resend": "^6.12.3",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
