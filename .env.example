# ============================================================
# FUNDAMENTAL MVP — 环境变量说明
# 复制本文件为 .env.local（本地开发）或在 Vercel Dashboard 逐条粘贴
# ============================================================

# ------------------------------------------------------------
# [必填] 数据库
# Vercel Serverless 无持久磁盘，不配置此项订单数据将在函数重启后丢失。
# 推荐：Neon (https://neon.tech) 或 Supabase Postgres 免费套餐
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------
# [必填-生产] 会话签名密钥
# Mock 模式（无 DATABASE_URL）下用于 HMAC-SHA256 签名 Cookie，防止伪造。
# 建议：openssl rand -base64 32
# 未配置时自动使用进程级随机密钥（开发可接受，生产必须设置）
# ------------------------------------------------------------
SESSION_SECRET=change_me_32_chars_random_string_here

# ------------------------------------------------------------
# [必填-生产] Stripe 支付
# STRIPE_SECRET_KEY    : Stripe Dashboard → Developers → API Keys → Secret key
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Webhooks → Signing secret
#                        （或 stripe listen --print-secret 本地测试）
# 未配置时 Stripe Checkout 按钮不显示，demo_instant 仍可用
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ------------------------------------------------------------
# [必填-生产] ERP Webhook 验签密钥
# ERP 回调 POST /api/integrations/erp/webhook 时用于 HMAC-SHA256 验签。
# 未配置时该端点返回 503；本地开发验收脚本会自动注入测试密钥。
# ------------------------------------------------------------
ERP_WEBHOOK_SECRET=your_erp_webhook_secret_here

# ------------------------------------------------------------
# [必填-生产] Integration Worker 鉴权密钥
# POST /api/integrations/worker/run 和 GET /api/cron/integration-worker
# 需在 Header 携带 X-Integration-Worker-Key: <此值> 或 Authorization: Bearer <此值>
# ------------------------------------------------------------
INTEGRATION_WORKER_KEY=your_worker_key_here

# ------------------------------------------------------------
# [可选] Resend 邮件（询价表单 / 联系邮件）
# https://resend.com — 注册后获取 API Key
# RESEND_FROM_EMAIL 须为 Resend 已验证域名下的地址；
# 测试可用 onboarding@resend.dev（仅能发往自己账号邮箱）
# ------------------------------------------------------------
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=you@example.com

# ------------------------------------------------------------
# [可选] 真实 ERP 推送地址
# 配置后 integration worker 会将订单推送至该 URL；
# 未配置时静默跳过（仅标记任务成功，适合 Demo）
# ------------------------------------------------------------
EXTERNAL_ERP_URL=https://your-erp.example.com/api/orders

# ------------------------------------------------------------
# [可选] 内部 AI 编辑器嵌入地址
# /b/ai-editor 页面的 iframe src；未配置时回退到内置默认地址
# ------------------------------------------------------------
NEXT_PUBLIC_CHAOHETI_DASHBOARD_URL=https://your-ai-editor.example.com/dashboard

# ------------------------------------------------------------
# [可选] 本地开发调试：模拟 ERP 推送失败（用于测试重试逻辑）
# 设为 1 时 executeErpOutbound 强制抛出错误
# ------------------------------------------------------------
# ERP_PUSH_SIMULATE_FAIL=1
