# Resend（https://resend.com）— Vercel 项目设置里粘贴相同变量
RESEND_API_KEY=re_xxxx

# 发件人：须为 Resend 已验证域名下的地址；测试可用 Resend 文档提供的 onboarding 地址
RESEND_FROM_EMAIL=onboarding@resend.dev

# 询价邮件收件地址（你的邮箱）
CONTACT_EMAIL=you@example.com

# --- DashScope 生图（服务端；勿提交真实 Key）---
# DASHSCOPE_API_KEY=
# DASHSCOPE_REGION=intl
# DASHSCOPE_T2I_MODEL=qwen-image-2.0
# DASHSCOPE_EDIT_MODEL=qwen-image-2.0-pro
# DASHSCOPE_MULTI_REF_MAX=3
# DASHSCOPE_TIMEOUT_MS=120000
